{
  "name": "lantern-ai",
  "version": "0.3.6",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "lint": "eslint packages/*/src --ext .ts,.tsx",
    "typecheck": "pnpm -r run typecheck",
    "dev": "pnpm -r --parallel run dev",
    "clean": "find . -name dist -type d | xargs rm -rf",
    "demo": "pnpm build && node demo.mjs"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^1.4.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ],
    "overrides": {
      "flatted": ">=3.4.2",
      "picomatch": ">=4.0.4",
      "undici": ">=6.24.0",
      "brace-expansion": ">=5.0.5",
      "cookie": ">=0.7.0",
      "path-to-regexp": ">=8.4.0"
    }
  }
}
